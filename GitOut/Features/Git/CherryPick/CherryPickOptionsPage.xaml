<UserControl
  x:Class="GitOut.Features.Git.CherryPick.CherryPickOptionsPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="clr-namespace:GitOut.Features.Git.CherryPick"
  mc:Ignorable="d"
  d:DesignHeight="300"
  d:DesignWidth="400"
  d:DataContext="{d:DesignInstance Type={x:Type local:CherryPickOptionsViewModel}}"
>
  <Border CornerRadius="8" Background="{DynamicResource MaterialBackgroundBackground}">
    <Grid Style="{StaticResource LayoutRootGridStyle}">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <StackPanel Margin="24 28">
        <TextBlock Text="Cherry pick commits" Style="{StaticResource Header5TextStyle}"  />
        <CheckBox
          Style="{StaticResource MaterialCheckBoxStyle}"
          Margin="0 4"
          IsChecked="{Binding Edit}"
          Content="Edit"
        />
        <CheckBox
          Style="{StaticResource MaterialCheckBoxStyle}"
          Margin="0 4"
          IsChecked="{Binding NoCommit}"
          Content="No commit"
        />
        <CheckBox
          Style="{StaticResource MaterialCheckBoxStyle}"
          Margin="0 4"
          IsChecked="{Binding AppendCherryPickLine}"
          Content="Append cherry-pick line"
        />
        <CheckBox
          Style="{StaticResource MaterialCheckBoxStyle}"
          Margin="0 4"
          IsChecked="{Binding FastForward}"
          Content="Fast forward"
        />
        <TextBlock
          Style="{StaticResource NormalTextStyle}"
          Margin="0 12 0 4"
          Text="Mainline parent number (e.g. 1 for merge commits):"
        />
        <TextBox
          Style="{StaticResource MaterialFormInputStyle}"
          Text="{Binding MainlineParentNumber, UpdateSourceTrigger=PropertyChanged}"
        />
      </StackPanel>
      <StackPanel Grid.Row="1" Margin="8 0" Orientation="Horizontal" HorizontalAlignment="Right">
        <Button
          Style="{StaticResource MaterialButtonStyle}"
          Command="{Binding CancelCommand}"
          Content="CANCEL"
        />
        <Button
          Style="{StaticResource MaterialButtonStyle}"
          Command="{Binding SetResultCommand}"
          Content="CHERRY PICK"
        />
      </StackPanel>
    </Grid>
  </Border>
</UserControl>
