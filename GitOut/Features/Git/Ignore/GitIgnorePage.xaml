<UserControl
  x:Class="GitOut.Features.Git.Ignore.GitIgnorePage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="clr-namespace:GitOut.Features.Git.Ignore"
  xmlns:wpfcommands="clr-namespace:GitOut.Features.Wpf.Commands"
  xmlns:attach="clr-namespace:GitOut.Features.Wpf.AttachedProperties"
  mc:Ignorable="d"
  d:DataContext="{d:DesignInstance local:GitIgnoreViewModel}"
  d:DesignHeight="450"
  d:DesignWidth="800"
>
  <UserControl.Resources>
    <Style
      x:Key="IgnoreRuleListStyle"
      TargetType="{x:Type ListView}"
      BasedOn="{StaticResource MaterialListStyle}"
    >
      <Setter Property="Background" Value="{StaticResource MaterialGray900}" />
      <Setter Property="ItemTemplate">
        <Setter.Value>
          <DataTemplate DataType="{x:Type local:GitIgnoreRule}">
            <Grid HorizontalAlignment="Stretch" ToolTip="{Binding Explanation}">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="40" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock
                TextElement.FontFamily="Consolas sans-serif"
                TextElement.FontSize="12"
                TextElement.Foreground="{DynamicResource MaterialGray400}"
                Text="{Binding LineNumber}"
                VerticalAlignment="Center"
                Margin="0 0 8 0"
              />
              <TextBlock
                Grid.Column="1"
                Text="{Binding Pattern}"
                Foreground="{DynamicResource MaterialForegroundBase}"
                Style="{StaticResource NormalTextStyle}"
                FontFamily="Consolas, Courier New, Monospace"
                FontWeight="Bold"
                VerticalAlignment="Center"
              />
            </Grid>
          </DataTemplate>
        </Setter.Value>
      </Setter>
      <Setter Property="ItemContainerStyle">
        <Setter.Value>
          <Style TargetType="{x:Type ListViewItem}">
            <Setter Property="Height" Value="22" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Foreground" Value="{DynamicResource MaterialForegroundBase}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter
              Property="Tag"
              Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}"
            />
            <Setter Property="ContextMenu">
              <Setter.Value>
                <ContextMenu>
                  <MenuItem
                    Header="Copy Pattern"
                    Command="{Binding PlacementTarget.Tag.CopyPatternCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                    CommandParameter="{Binding}"
                  >
                    <MenuItem.Icon>
                      <Path
                        Fill="{DynamicResource MaterialForegroundBase}"
                        Data="{StaticResource ContentCopy}"
                      />
                    </MenuItem.Icon>
                  </MenuItem>
                </ContextMenu>
              </Setter.Value>
            </Setter>
          </Style>
        </Setter.Value>
      </Setter>
    </Style>
  </UserControl.Resources>
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    <Grid Style="{StaticResource MaterialToolbarStyle}">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <Button
        Style="{StaticResource MaterialButtonStyle}"
        Command="{x:Static wpfcommands:Navigate.Back}"
        ToolTip="Back"
      >
        <Path
          Height="24"
          Fill="{DynamicResource MaterialForegroundBase}"
          Data="{StaticResource ArrowLeft}"
        />
      </Button>
      <TextBlock
        Grid.Column="1"
        Text=".gitignore"
        Style="{StaticResource MaterialToolbarHeaderStyle}"
      />
      <Button
        Grid.Column="2"
        Style="{StaticResource MaterialButtonStyle}"
        Command="{Binding OpenIgnoreFileCommand}"
        ToolTip="Open in editor"
      >
        <Path
          Height="24"
          Fill="{DynamicResource MaterialForegroundBase}"
          Data="{StaticResource OpenInNew}"
        />
      </Button>
    </Grid>
    <Border Grid.Row="1" Style="{StaticResource CardPanelStyle}" Margin="8">
      <Grid Margin="8">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBox
          Grid.Column="0"
          Style="{StaticResource MaterialInputStyle}"
          Text="{Binding CheckPathText, UpdateSourceTrigger=PropertyChanged}"
          attach:InputBindings.EnterCommand="{Binding CheckPathCommand}"
          AutomationProperties.HelpText="Check path (e.g. bin/Debug/app.exe)"
          Margin="0 0 8 0"
        />
        <Button
          Grid.Column="1"
          Command="{Binding CheckPathCommand}"
          Style="{StaticResource MaterialButtonStyle}"
          Content="CHECK"
        />
        <TextBlock
          Grid.Row="1"
          Grid.ColumnSpan="2"
          Text="{Binding CheckResult}"
          Style="{StaticResource NormalTextStyle}"
          Margin="0 8 0 0"
          Foreground="{DynamicResource MaterialForegroundBase}"
        />
      </Grid>
    </Border>
    <ListView
      Grid.Row="2"
      ItemsSource="{Binding Rules}"
      SelectedItem="{Binding HighlightedRule}"
      Style="{StaticResource IgnoreRuleListStyle}"
      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
      attach:ListBoxBehavior.ScrollSelectedIntoView="True"
    ></ListView>
  </Grid>
</UserControl>
