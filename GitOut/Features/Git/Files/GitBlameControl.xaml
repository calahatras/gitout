<UserControl
  x:Class="GitOut.Features.Git.Files.GitBlameControl"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:git="clr-namespace:GitOut.Features.Git"
  xmlns:local="clr-namespace:GitOut.Features.Git.Log"
  xmlns:files="clr-namespace:GitOut.Features.Git.Files"
  xmlns:converters="clr-namespace:GitOut.Features.Wpf.Converters"
  mc:Ignorable="d"
  d:DesignHeight="450"
  d:DesignWidth="800"
>
  <UserControl.Resources>
    <converters:SubstringConverter x:Key="SubstringConverter" />
  </UserControl.Resources>
  <ScrollViewer
    HorizontalScrollBarVisibility="Auto"
    VerticalScrollBarVisibility="Auto"
    Background="{DynamicResource MaterialBackgroundBackground}"
  >
    <ItemsControl ItemsSource="{Binding BlameResult.Hunks}" Margin="8">
      <ItemsControl.ItemTemplate>
        <DataTemplate DataType="{x:Type files:GitBlameHunkViewModel}">
          <!-- Commit Info on Left -->
          <Border
            Grid.Column="0"
            BorderBrush="{StaticResource MaterialLightDividers}"
            BorderThickness="0,1,0,0"
          >
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <StackPanel>
                <Button
                  Style="{StaticResource MaterialButtonStyle}"
                  Margin="0"
                  Padding="0"
                  Command="{Binding DataContext.SelectCommitCommand, RelativeSource={RelativeSource AncestorType={x:Type local:GitLogPage}}}"
                  CommandParameter="{Binding CommitId}"
                  HorizontalAlignment="Left"
                  MinHeight="18"
                >
                  <TextBlock
                    FontFamily="Consolas"
                    Foreground="{DynamicResource PrimaryHueMidBrush}"
                  >
                    <Run Text="{Binding AuthorDate, Mode=OneWay, StringFormat=d}" />
                    <Run Text="{Binding CommitId.Hash, Mode=OneWay, Converter={StaticResource SubstringConverter}, ConverterParameter=7}" />
                    <Run Text="{Binding Author, Mode=OneWay}" />
                  </TextBlock>
                </Button>
              </StackPanel>
              <!-- Hunk Lines on Right -->
              <Grid Grid.Column="1" Margin="8,0,0,0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="50" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <ItemsControl Grid.Column="0" ItemsSource="{Binding LineNumbers}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <TextBlock
                        Text="{Binding}"
                        FontFamily="Consolas sans-serif"
                        FontSize="12"
                        Foreground="{DynamicResource MaterialDesignBodyLight}"
                        TextAlignment="Right"
                        Margin="0,0,8,0"
                      />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <FlowDocumentScrollViewer
                  Grid.Column="1"
                  Document="{Binding Document}"
                  VerticalScrollBarVisibility="Disabled"
                  HorizontalScrollBarVisibility="Disabled"
                  Foreground="{DynamicResource MaterialDesignBody}"
                />
              </Grid>
            </Grid>
          </Border>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>
  </ScrollViewer>
</UserControl>
